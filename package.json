{
  "name": "decky-ost-music",
  "version": "1.8.1",
  "description": "Play theme songs on your game pages",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "setup": "pnpm i",
    "update:ui": "pnpm update @decky/ui --latest",
    "update:api": "pnpm update @decky/api --latest",
    "update:rollup": "pnpm update @decky/rollup --latest",
    "build:all": "pnpm i && pnpm run build",
    "deck:folders": "node scripts/deck.mjs createfolders",
    "deck:chmod": "node scripts/deck.mjs chmod",
    "deploy": "node scripts/deck.mjs deploy",
    "allinone": "pnpm run build:all && pnpm run deploy",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Allive/DeckyOstMusic"
  },
  "keywords": [
    "decky",
    "plugin",
    "plugin-template",
    "steam-deck",
    "deck"
  ],
  "author": "Allive",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/Allive/DeckyOstMusic/issues"
  },
  "homepage": "https://github.com/Allive/DeckyOstMusic#readme",
  "remote_binary": [
    {
      "name": "yt-dlp",
      "url": "https://github.com/yt-dlp/yt-dlp/releases/download/2026.06.09/yt-dlp",
      "sha256hash": "e5d57466682cfa9d61e9cf7c8a4f09b00f4a62af37d3bbdc4bcffdf63615feac"
    }
  ],
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.8.2",
    "@eslint/js": "^9.15.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/webpack": "^5.28.5",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "prettier": "^3.4.1",
    "rollup": "^4.27.4",
    "rollup-plugin-external-globals": "^0.13.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.2",
    "localforage": "^1.10.0",
    "qrcode.react": "^4.1.0",
    "react-icons": "^5.3.0",
    "tslib": "^2.8.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    },
    "supportedArchitectures": {
      "os": [
        "current"
      ],
      "cpu": [
        "current"
      ],
      "libc": [
        "glibc",
        "musl"
      ]
    }
  }
}
